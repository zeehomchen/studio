// Prisma Schema for 设计师个人网站
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户模型 ====================
enum Role {
  ADMIN
  VIEWER
}

enum Locale {
  ZH
  EN
}

model User {
  id        String   @id @default(cuid()) @db.VarChar(100)
  email     String?  @unique @db.VarChar(100)
  password  String
  role      Role     @default(ADMIN)
  name      String?  @db.VarChar(100)
  avatar    String?  @db.Text
  bio       String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
  works     Work[]
}

// ==================== 文章模型 ====================
model Post {
  id           String     @id @default(cuid()) @db.VarChar(100)
  title        String     @db.VarChar(255)
  slug         String     @unique @db.VarChar(150) // 缩减索引长度
  content      Json
  excerpt      String?    @db.Text
  coverImage   String?    @db.Text
  coverRatio   String     @default("3:4") @db.VarChar(10)
  status       PostStatus @default(DRAFT)
  categoryId   String?    @db.VarChar(100)
  category     Category?  @relation(fields: [categoryId], references: [id])
  tags         Tag[]
  authorId     String     @db.VarChar(100)
  author       User       @relation(fields: [authorId], references: [id])
  titleI18n    Json?
  slugI18n     Json?
  excerptI18n  Json?
  contentI18n  Json?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  publishedAt  DateTime?

  @@index([status])
  @@index([categoryId])
  @@index([authorId])
}

// ==================== 作品模型 ====================
model Work {
  id              String        @id @default(cuid()) @db.VarChar(100)
  title           String        @db.VarChar(255)
  slug            String        @unique @db.VarChar(150) // 缩减索引长度
  workType        WorkType      @default(DESIGN)
  description     String?       @db.Text
  content         Json?
  coverImage      String        @db.Text
  coverRatio      String        @default("3:4") @db.VarChar(10)
  images          Json
  currentVersion  String?       @db.VarChar(20)
  price           Decimal?      @db.Decimal(10, 2)
  isFree          Boolean       @default(false)
  figmaUrl        String?       @db.Text
  deliveryUrl     String?       @db.Text
  demoUrl         String?       @db.Text
  demoQrCode      String?       @db.Text
  showTitle       Boolean       @default(true)
  showDescription Boolean       @default(true)
  showPrice       Boolean       @default(true)
  status          WorkStatus    @default(DRAFT)
  categoryId      String?       @db.VarChar(100)
  category        Category?     @relation(fields: [categoryId], references: [id])
  authorId        String        @db.VarChar(100)
  author          User          @relation(fields: [authorId], references: [id])
  tags            Tag[]
  orders          Order[]
  versions        WorkVersion[]
  titleI18n       Json?
  slugI18n        Json?
  descriptionI18n Json?
  contentI18n     Json?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([workType])
  @@index([categoryId])
  @@index([authorId])
}

// ==================== 复合索引专项修正 (最关键) ====================
model WorkVersion {
  id          String   @id @default(cuid()) @db.VarChar(100)
  workId      String   @db.VarChar(100)
  work        Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  version     String   @db.VarChar(20)
  price       Decimal  @db.Decimal(10, 2)
  changelog   String?  @db.Text
  figmaUrl    String?  @db.Text
  deliveryUrl String?  @db.Text
  createdAt   DateTime @default(now())
  orders      Order[]

  @@unique([workId, version]) // 总长度: (100+20)*4 = 480 < 1000
}

model KnowledgeSource {
  id         String                @id @default(cuid()) @db.VarChar(100)
  sourceType KnowledgeSourceType
  sourceId   String                @db.VarChar(100)
  locale     Locale                @default(ZH)
  slug       String?               @db.VarChar(100)
  title      String                @db.VarChar(255)
  url        String                @db.Text
  status     KnowledgeSourceStatus @default(ACTIVE)
  hash       String                @db.VarChar(64)
  updatedAt  DateTime              @updatedAt
  chunks     KnowledgeChunk[]
  assets     KnowledgeAsset[]

  @@unique([sourceType, sourceId, locale]) // 这里是之前的报错大户
}

model KnowledgeChunk {
  id             String          @id @default(cuid()) @db.VarChar(100)
  sourceId       String          @db.VarChar(100)
  source         KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chunkIndex     Int
  contentText    String          @db.LongText
  contentTokens  Int             @default(0)
  locale         Locale          @default(ZH)
  embedding      Json?
  createdAt      DateTime        @default(now())

  @@unique([sourceId, chunkIndex])
}

// ==================== 订单模型 ====================
model Order {
  id            String       @id @default(cuid()) @db.VarChar(100)
  orderNo       String       @unique @db.VarChar(64)
  workId        String       @db.VarChar(100)
  work          Work         @relation(fields: [workId], references: [id])
  versionId     String?      @db.VarChar(100)
  version       WorkVersion? @relation(fields: [versionId], references: [id])
  // 刚才遗漏了这两个关键字段，现在补回来：
  amount        Decimal      @db.Decimal(10, 2)
  status        OrderStatus  @default(PENDING)
  
  buyerEmail    String       @db.VarChar(150)
  buyerName     String?      @db.VarChar(100)
  buyerLocale   Locale       @default(ZH)
  paymentId     String?      @db.VarChar(64) // 微信支付订单号
  
  // 核心修复点：
  paidAt        DateTime?    
  
  downloadToken String?      @unique @db.VarChar(64)
  downloadCount Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
  @@index([workId])
  @@index([buyerEmail])
}

// ==================== 分类与标签 ====================
model Category {
  id        String          @id @default(cuid()) @db.VarChar(100)
  name      String          @db.VarChar(100)
  nameI18n  Json?
  slug      String          @unique @db.VarChar(100)
  slugI18n  Json?
  type      CategoryType
  posts     Post[]
  works     Work[]
  tutorials VideoTutorial[]
}

model Tag {
  id        String          @id @default(cuid()) @db.VarChar(100)
  name      String          @unique @db.VarChar(50)
  nameI18n  Json?
  posts     Post[]
  works     Work[]
  tutorials VideoTutorial[]
}

// ==================== 网站设置 ====================
model Settings {
  id              String   @id @db.VarChar(100)
  siteName        String   @default("Fan's Studio") @db.VarChar(255)
  defaultLocale   Locale   @default(ZH)
  avatar          String?  @db.Text
  socialLinks     Json?    // 恢复字段：社交链接
  about           Json?    // 恢复字段：关于页内容
  nav             Json?    // 恢复字段：导航品牌与名称
  navI18n         Json?    // 恢复字段：导航多语言
  pageCopy        Json?    // 恢复字段：页头介绍
  pageCopyI18n    Json?    // 恢复字段：页头介绍多语言
  aiAssistant     Json?    // 恢复字段：AI 助手配置
  aiAssistantI18n Json?    // 恢复字段：AI 助手多语言
  aiModelConfig   Json?    // 恢复字段：AI 模型配置
  theme           Json?    // 恢复字段：主题配置
  footer          Json?    // 恢复字段：页脚配置
  footerI18n      Json?    // 恢复字段：页脚多语言
  updatedAt       DateTime @updatedAt
}

// 其余模型保持原样，但 ID 统一限制...
model Media {
  id         String   @id @default(cuid()) @db.VarChar(100)
  name       String   @db.VarChar(255)
  url        String   @db.Text
  type       String   @db.VarChar(50)
  size       Int       @default(0)
  width      Int?
  height     Int?
  entityType String   @db.VarChar(50)
  entityId   String   @db.VarChar(100)
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

model VideoTutorial {
  id              String    @id @default(cuid()) @db.VarChar(100)
  title           String    @db.VarChar(255)
  slug            String    @unique @db.VarChar(150)
  videoUrl        String    @db.Text
  description     String?   @db.Text
  thumbnail       String?   @db.Text
  coverRatio      String    @default("3:4") @db.VarChar(10)
  categoryId      String?   @db.VarChar(100)
  category        Category? @relation(fields: [categoryId], references: [id])
  tags            Tag[]
  sortOrder       Int       @default(0)
  titleI18n       Json?
  slugI18n        Json?
  descriptionI18n Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model KnowledgeAsset {
  id         String            @id @default(cuid()) @db.VarChar(100)
  sourceId   String            @db.VarChar(100)
  source     KnowledgeSource   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  assetType  KnowledgeAssetType @default(IMAGE)
  url        String            @db.Text
  createdAt  DateTime          @default(now())

  @@index([sourceId])
}

model KnowledgeSyncJob {
  id         String             @id @default(cuid()) @db.VarChar(100)
  jobType    KnowledgeJobType
  status     KnowledgeJobStatus @default(PENDING)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
}

// ==================== 枚举类型 ====================
enum PostStatus {
  DRAFT
  PUBLISHED
}

enum WorkStatus {
  DRAFT
  PUBLISHED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum CategoryType {
  POST
  WORK
  DESIGN
  DEVELOPMENT
  TUTORIAL
}

enum WorkType {
  DESIGN
  DEVELOPMENT
}

enum KnowledgeSourceType {
  POST
  WORK
  TUTORIAL
  SETTINGS
}

enum KnowledgeSourceStatus {
  ACTIVE
  DELETED
}

enum KnowledgeAssetType {
  IMAGE
}

enum KnowledgeJobType {
  UPSERT_SOURCE
  DELETE_SOURCE
  FULL_REBUILD
}

enum KnowledgeJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}